{
  "version": 2,
  "builds": [
      {
        "src": "apps/lens-lounge/src/main.ts",
        "use": "@vercel/node"
      }
],
"routes": [
  {
    "src": "/(.*)",
    "dest": "apps/lens-lounge/src/main.ts",
    "methods": [
          "GET",
          "POST",
          "PUT",
          "DELETE"
       ]
    }
  ]
}
